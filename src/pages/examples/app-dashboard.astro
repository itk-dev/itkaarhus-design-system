---
import Layout from '../../layouts/Layout.astro';
const base = import.meta.env.BASE_URL;
const file = 'examples/embed/app-dashboard.html';
---

<Layout title="App dashboard" bleed={true}>
  <iframe class="ex-frame" src={`${base}${file}`} title="Mit Aarhus — app dashboard" loading="lazy"></iframe>
</Layout>

<style>
  .ex-frame { flex: 1; width: 100%; border: 0; background: var(--itkaarhus-gray-50); }
</style>
