---
import Layout from '../layouts/Layout.astro';
const base = import.meta.env.BASE_URL;
---

<Layout title="Components">
  <div class="page">
    <div class="eyebrow">Design system · Components</div>
    <h1 class="title">Utility first, calm by default.</h1>
    <p class="lede">A small set of primitives that compose into every surface — from public sites to internal admin tools. Borrows its restraint from Danish gov conventions, then lets the palette do the lifting.</p>

    <h2 class="sh" id="buttons">Buttons</h2>
    <p class="sub">Blue leads (primary); secondary is a neutral outline. A destructive button uses <strong>danger</strong> (<code>--itkaarhus-danger-500</code>) — never the secondary brand colour. For low-emphasis actions, use a <strong>link</strong> rather than a borderless button so the tabbable area stays clear.</p>
    <div class="demo stack" style="gap:28px">
      <div>
        <div class="demo-label">Variants</div>
        <div class="row">
          <button class="itkaarhus-btn itkaarhus-btn--primary">Primary action</button>
          <button class="itkaarhus-btn itkaarhus-btn--secondary">Secondary</button>
          <button class="itkaarhus-btn itkaarhus-btn--danger">Delete</button>
        </div>
      </div>
      <div>
        <div class="demo-label">Link</div>
        <div class="row">
          <a class="itkaarhus-link" href="#buttons">Læs mere</a>
          <a class="itkaarhus-link" href="#buttons">Se alle projekter →</a>
        </div>
      </div>
      <div>
        <div class="demo-label">Sizes</div>
        <div class="row" style="align-items:baseline">
          <button class="itkaarhus-btn itkaarhus-btn--primary itkaarhus-btn--sm">Small</button>
          <button class="itkaarhus-btn itkaarhus-btn--primary">Default</button>
          <button class="itkaarhus-btn itkaarhus-btn--primary itkaarhus-btn--lg">Large</button>
        </div>
      </div>
      <div>
        <div class="demo-label">States</div>
        <div class="row">
          <button class="itkaarhus-btn itkaarhus-btn--primary">Default</button>
          <button class="itkaarhus-btn itkaarhus-btn--primary is-hover">Hover</button>
          <button class="itkaarhus-btn itkaarhus-btn--primary" disabled>Disabled</button>
        </div>
      </div>
    </div>

    <h2 class="sh" id="tags">Tags &amp; status</h2>
    <p class="sub">One badge component for both category tags and status. Each role is a soft <code>-100</code> surface with <code>-700</code> text — an AA-contrast pairing (≥ 4.5:1) on white. The leading dot is optional via <code>--dot</code>; drop it for neutral metadata.</p>
    <div class="demo stack" style="gap:24px">
      <div>
        <div class="demo-label">Semantic roles</div>
        <div class="row">
          <span class="itkaarhus-tag itkaarhus-tag--info itkaarhus-tag--dot">Sendt til HR</span>
          <span class="itkaarhus-tag itkaarhus-tag--success itkaarhus-tag--dot">Godkendt</span>
          <span class="itkaarhus-tag itkaarhus-tag--warning itkaarhus-tag--dot">Afventer</span>
          <span class="itkaarhus-tag itkaarhus-tag--danger itkaarhus-tag--dot">Afvist</span>
          <span class="itkaarhus-tag itkaarhus-tag--secondary itkaarhus-tag--dot">Fremhævet</span>
        </div>
      </div>
      <div>
        <div class="demo-label">Brand &amp; neutral</div>
        <div class="row">
          <span class="itkaarhus-tag itkaarhus-tag--primary itkaarhus-tag--dot">Development</span>
          <span class="itkaarhus-tag itkaarhus-tag--neutral itkaarhus-tag--dot">Pilot</span>
          <span class="itkaarhus-tag itkaarhus-tag--neutral">v2.4.1</span>
        </div>
      </div>
    </div>

    <h2 class="sh" id="inputs">Inputs</h2>
    <div class="demo stack" style="gap:28px">
      <div>
        <div class="demo-label">Text, select &amp; search</div>
        <div class="row" style="align-items:flex-start; gap:24px">
          <div class="itkaarhus-field">
            <label for="ex1">E-mail</label>
            <input id="ex1" type="email" placeholder="navn@aarhus.dk" />
            <div class="help">Vi sender aldrig mails uden tilladelse.</div>
          </div>
          <div class="itkaarhus-field">
            <label for="ex2">Afdeling</label>
            <div class="itkaarhus-select">
              <select id="ex2">
                <option>Development</option>
                <option>Tech Lab</option>
                <option>Grafisk Service</option>
              </select>
              <svg class="caret" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="m6 9 6 6 6-6" /></svg>
            </div>
          </div>
          <div class="itkaarhus-field">
            <label for="ex3">Søg</label>
            <input id="ex3" type="search" placeholder="Søg i projekter …" />
          </div>
        </div>
      </div>

      <div>
        <div class="demo-label">Checkbox &amp; radio</div>
        <div class="row" style="gap:32px; align-items:flex-start">
          <div class="choice-group">
            <label class="choice"><input type="checkbox" checked /> <span>Send mig nyhedsbrev</span></label>
            <label class="choice"><input type="checkbox" /> <span>Tillad analyse-cookies</span></label>
            <label class="choice"><input type="checkbox" disabled /> <span>Slået fra</span></label>
          </div>
          <div class="choice-group">
            <label class="choice"><input type="radio" name="afd" checked /> <span>Hele kommunen</span></label>
            <label class="choice"><input type="radio" name="afd" /> <span>Min afdeling</span></label>
            <label class="choice"><input type="radio" name="afd" disabled /> <span>Ekstern (utilgængelig)</span></label>
          </div>
        </div>
      </div>

      <div>
        <div class="demo-label">Toggle</div>
        <div class="row" style="gap:24px">
          <label class="itkaarhus-toggle"><input type="checkbox" checked /><span class="track"></span><span class="toggle-label">Notifikationer</span></label>
          <label class="itkaarhus-toggle"><input type="checkbox" /><span class="track"></span><span class="toggle-label">Mørk tilstand</span></label>
          <label class="itkaarhus-toggle"><input type="checkbox" disabled /><span class="track"></span><span class="toggle-label">Beta (låst)</span></label>
        </div>
      </div>
    </div>

    <h2 class="sh" id="cards">Cards</h2>
    <div class="card-grid">
      <article class="itkaarhus-card">
        <div class="itkaarhus-card__image"></div>
        <div class="itkaarhus-card__body">
          <div class="itkaarhus-card__kicker">Projektnyhed</div>
          <h3 class="itkaarhus-card__title">Vilde Teknologier slippes løs på Dokk1</h3>
          <p class="itkaarhus-card__excerpt">Tre dage med udstilling, talks og prototyper i Aarhus Kommunes teknologifestival.</p>
          <div class="itkaarhus-card__foot"><span>14 · apr · 2026</span><span>— 4 min</span></div>
        </div>
      </article>
      <article class="itkaarhus-card">
        <div class="itkaarhus-card__image" style="background: var(--itkaarhus-success-500);"></div>
        <div class="itkaarhus-card__body">
          <div class="itkaarhus-card__kicker">Open source</div>
          <h3 class="itkaarhus-card__title">OS2Forms reaches version 4.0</h3>
          <p class="itkaarhus-card__excerpt">Ny formular-motor med delte skemaer og bedre tilgængelighed for alle landets kommuner.</p>
          <div class="itkaarhus-card__foot"><span>github/os2forms</span><span>★ 142</span></div>
        </div>
      </article>
      <article class="itkaarhus-card">
        <div class="itkaarhus-card__image" style="background: var(--itkaarhus-coral-500);"></div>
        <div class="itkaarhus-card__body">
          <div class="itkaarhus-card__kicker">Service</div>
          <h3 class="itkaarhus-card__title">Infostander på biblioteker</h3>
          <p class="itkaarhus-card__excerpt">Digitale skærme samler nyheder, arrangementer og vejvisning — open source, drevet af Aarhus Kommune.</p>
          <div class="itkaarhus-card__foot"><span>Drift</span><span>24/7</span></div>
        </div>
      </article>
    </div>

    <h2 class="sh" id="callouts">Callouts</h2>
    <div class="demo stack">
      <div class="itkaarhus-callout itkaarhus-callout--info">
        <div class="ic"><svg viewBox="0 0 24 24"><circle cx="12" cy="12" r="10" /><path d="M12 16v-4" /><path d="M12 8h.01" /></svg></div>
        <div><strong>Planlagt vedligehold</strong>Hetzner-hosting opdateres lørdag 04:00 – 05:30. Kortere nedetid forventes.</div>
      </div>
      <div class="itkaarhus-callout itkaarhus-callout--success">
        <div class="ic"><svg viewBox="0 0 24 24"><path d="M20 6 9 17l-5-5" /></svg></div>
        <div><strong>Deploy lykkedes</strong>borger-api v2.4.1 er live i produktion — alle regressionstests grønne.</div>
      </div>
      <div class="itkaarhus-callout itkaarhus-callout--warn">
        <div class="ic"><svg viewBox="0 0 24 24"><path d="M10.29 3.86 1.82 18a2 2 0 0 0 1.71 3h16.94a2 2 0 0 0 1.71-3L13.71 3.86a2 2 0 0 0-3.42 0z" /><path d="M12 9v4" /><path d="M12 17h.01" /></svg></div>
        <div><strong>Bemærk</strong>Azure-migration er pauseret indtil kontraktgennemgang er afsluttet.</div>
      </div>
    </div>

    <h2 class="sh" id="stats">Stats</h2>
    <div class="stat-grid">
      <div class="stat"><span class="n">333</span><span class="l">Repos på GitHub</span></div>
      <div class="stat success"><span class="n">27</span><span class="l">Aktive projekter</span></div>
      <div class="stat info"><span class="n">13</span><span class="l">Kommuner i GovTech MJ</span></div>
      <div class="stat danger"><span class="n">2030</span><span class="l">Klimaneutral smart city</span></div>
    </div>

    <h2 class="sh" id="navigation">Navigation &amp; breadcrumb</h2>
    <div class="nav-demo">
      <a class="brand" href="#">
        <img src={`${base}assets/logos/aak-favicon.ico`} alt="" width="24" height="24" />
        <span class="product">[Product name]</span>
      </a>
      <ul>
        <li><a href="#" class="active">Nyheder</a></li>
        <li><a href="#">Om os</a></li>
        <li><a href="#">Projekter</a></li>
        <li><a href="#">Kontakt</a></li>
      </ul>
      <div class="spacer"></div>
      <a href="#" style="font-size:13px; color:var(--itkaarhus-gray-500); text-decoration:none">English ↗</a>
    </div>
    <div class="bc" style="margin-top:16px">
      <a href="#">Forside</a><span class="sep">/</span>
      <a href="#">Om os</a><span class="sep">/</span>
      <a href="#">Afdelinger</a><span class="sep">/</span>
      <span class="cur">Udvikling</span>
    </div>

    <h2 class="sh" id="editorial">Editorial type</h2>
    <p class="sub">Newsreader supplements Inter on website-style surfaces — heroes, overviews, KPI numbers. App chrome stays Inter. Coral (<code>--itkaarhus-coral-500</code>) is the secondary accent.</p>
    <div class="demo">
      <div class="ed-eyebrow">Arbejdsmiljø · Overblik</div>
      <h3 class="ed-title">En <em>tryg</em> arbejdsplads starter med overblik.</h3>
      <p class="ed-lede">Saml indsatser, ansvar og deadlines ét sted. Serif-overskrifter giver de redaktionelle flader ro og tyngde; den blå farve fører an, korallen accentuerer.</p>
    </div>

    <h2 class="sh" id="kpi">KPI cards</h2>
    <p class="sub">Stat tiles with serif, tabular numbers. Value tone follows the status roles. From both prototypes' overview pages.</p>
    <div class="kpi-grid">
      <div class="kpi"><span class="l">Åbne indsatser</span><span class="v">42</span></div>
      <div class="kpi"><span class="l">Løst i år</span><span class="v ok">128</span></div>
      <div class="kpi"><span class="l">Forfaldne</span><span class="v warn">7</span></div>
      <div class="kpi"><span class="l">Høj risiko</span><span class="v danger">3</span></div>
    </div>

    <h2 class="sh" id="table">Data table — expandable rows</h2>
    <p class="sub">Dense application table. The toggle chevron rotates 180° when open; the detail row animates with a <code>max-height</code> transition. Wrap in <code>overflow-x:auto</code> and add <code>--sticky-actions</code> to pin the last column. From the lønforhandling prototype.</p>
    <div class="demo" style="padding:0; overflow:hidden">
      <table class="dt">
        <thead><tr><th>Medarbejder</th><th>Trin</th><th>Beregnet</th><th>Status</th></tr></thead>
        <tbody>
          <tr>
            <td><button class="toggle open" type="button" aria-expanded="true"><svg class="chev" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="m6 9 6 6 6-6" /></svg>Anders Jensen</button></td>
            <td>37</td>
            <td><span class="calc">+1 250 kr.</span></td>
            <td><span class="itkaarhus-tag itkaarhus-tag--info itkaarhus-tag--dot">Sendt til HR</span></td>
          </tr>
          <tr class="detail"><td colspan="4">Forhandlingshistorik · Lønsammensætning — detaljer udfoldes her.</td></tr>
          <tr>
            <td><button class="toggle" type="button" aria-expanded="false"><svg class="chev" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="m6 9 6 6 6-6" /></svg>Mette Sørensen</button></td>
            <td>35</td>
            <td><span class="calc">+900 kr.</span></td>
            <td><span class="itkaarhus-tag itkaarhus-tag--success itkaarhus-tag--dot">Godkendt</span></td>
          </tr>
        </tbody>
      </table>
    </div>

    <h2 class="sh" id="timeline">Timeline</h2>
    <p class="sub">Activity log with state-colored dots and a connector line. From the arbejdsmiljø prototype.</p>
    <div class="demo">
      <div class="tl">
        <div class="tl-entry"><span class="tl-dot"><svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><path d="M20 6 9 17l-5-5" /></svg></span><div><p class="summary">Handleplan oprettet</p><span class="when">14. apr 2026</span></div></div>
        <div class="tl-entry"><span class="tl-dot"><svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><path d="M20 6 9 17l-5-5" /></svg></span><div><p class="summary">Delt med arbejdsmiljøgruppen</p><span class="when">16. apr 2026</span></div></div>
      </div>
    </div>
  </div>
</Layout>

<style>
  body { padding: 48px; font-family: var(--itkaarhus-font-sans); }
  .page { max-width: 1040px; margin: 0 auto; }
  .eyebrow { font-size: 12px; letter-spacing: 0.18em; text-transform: uppercase; color: var(--itkaarhus-gray-500); font-weight: 600; }
  h1.title { font-size: 44px; line-height: 1.05; margin: 8px 0 16px; letter-spacing: -0.02em; font-weight: 700; }
  p.lede { font-size: 18px; color: var(--itkaarhus-gray-700); max-width: 640px; margin: 0 0 40px; }
  h2.sh { font-size: 22px; margin: 48px 0 16px; font-weight: 600; letter-spacing: -0.01em; scroll-margin-top: 24px; }
  .sub { font-size: 13px; color: var(--itkaarhus-gray-500); margin: -8px 0 20px; max-width: 640px; }

  .demo { border: 1px solid var(--itkaarhus-gray-200); border-radius: 12px; padding: 32px; background: #fff; }
  .row { display: flex; gap: 12px; flex-wrap: wrap; align-items: center; }
  .stack { display: flex; flex-direction: column; gap: 12px; }

  /* -- Buttons ------------------------------------------------ */
  .itkaarhus-btn {
    display: inline-flex; align-items: center; gap: 8px;
    font-family: inherit; font-weight: 600; font-size: 15px;
    padding: 12px 20px; border-radius: 6px; border: 1px solid transparent;
    cursor: pointer; line-height: 1; letter-spacing: -0.005em;
    transition: background .15s, color .15s, border-color .15s;
  }
  .itkaarhus-btn:focus-visible { outline: none; box-shadow: var(--itkaarhus-focus); }
  .itkaarhus-btn:disabled { opacity: .5; cursor: not-allowed; }
  /* Primary — blue leads */
  .itkaarhus-btn--primary { background: var(--itkaarhus-blue-500); color: #fff; }
  .itkaarhus-btn--primary:hover:not(:disabled), .itkaarhus-btn--primary.is-hover { background: var(--itkaarhus-primary-hover); }
  /* Secondary — neutral outline */
  .itkaarhus-btn--secondary { background: #fff; color: var(--itkaarhus-gray-900); border-color: var(--itkaarhus-gray-300); }
  .itkaarhus-btn--secondary:hover:not(:disabled), .itkaarhus-btn--secondary.is-hover { border-color: var(--itkaarhus-gray-500); background: var(--itkaarhus-gray-50); }
  /* Danger — destructive only, used rarely */
  .itkaarhus-btn--danger { background: var(--itkaarhus-danger-500); color: #fff; }
  .itkaarhus-btn--danger:hover:not(:disabled), .itkaarhus-btn--danger.is-hover { background: var(--itkaarhus-danger-700); }
  .itkaarhus-btn--sm { padding: 8px 14px; font-size: 13px; }
  .itkaarhus-btn--lg { padding: 16px 28px; font-size: 17px; }

  /* Link — low-emphasis action. A real anchor, underlined, with a clear focus ring,
     rather than a borderless button whose tabbable area is ambiguous. */
  .itkaarhus-link {
    display: inline-flex; align-items: center; gap: 6px;
    font-family: inherit; font-weight: 600; font-size: 15px;
    color: var(--itkaarhus-blue-500); text-decoration: underline;
    text-underline-offset: 2px; text-decoration-thickness: 1px;
    border-radius: var(--itkaarhus-radius-1); cursor: pointer;
  }
  .itkaarhus-link:hover { color: var(--itkaarhus-primary-hover); }
  .itkaarhus-link:focus-visible { outline: none; box-shadow: var(--itkaarhus-focus); }

  .demo-label { font-size: 11px; font-weight: 600; letter-spacing: 0.12em; text-transform: uppercase; color: var(--itkaarhus-gray-500); margin-bottom: 12px; }

  /* -- Tags / status badges ----------------------------------- */
  /* One component for category tags and status. Every role is a soft -100
     surface with -700 text — an AA-contrast pairing on white. */
  .itkaarhus-tag { display: inline-flex; align-items: center; gap: 6px; padding: 4px 10px; border-radius: var(--itkaarhus-radius-pill); font-size: 12px; font-weight: 600; letter-spacing: 0.02em; }
  /* Optional leading dot (status use); omit for plain category/metadata tags. */
  .itkaarhus-tag--dot::before { content:""; width:6px; height:6px; border-radius:50%; background: currentColor; opacity:.8; }
  .itkaarhus-tag--neutral   { background: var(--itkaarhus-gray-100);    color: var(--itkaarhus-gray-700); }
  .itkaarhus-tag--primary   { background: var(--itkaarhus-blue-50);     color: var(--itkaarhus-blue-700); }
  /* Text steps chosen for ≥ 4.5:1 (AA) contrast on each soft surface. */
  .itkaarhus-tag--info      { background: var(--itkaarhus-info-soft);    color: var(--itkaarhus-info-800); }
  .itkaarhus-tag--success   { background: var(--itkaarhus-success-soft); color: var(--itkaarhus-success-700); }
  .itkaarhus-tag--warning   { background: var(--itkaarhus-warning-soft); color: var(--itkaarhus-warning-900); }
  .itkaarhus-tag--danger    { background: var(--itkaarhus-danger-soft);  color: var(--itkaarhus-danger-700); }
  .itkaarhus-tag--secondary { background: var(--itkaarhus-coral-100);   color: var(--itkaarhus-coral-800); }

  /* -- Input -------------------------------------------------- */
  .itkaarhus-field { display: flex; flex-direction: column; gap: 6px; max-width: 320px; }
  .itkaarhus-field label { font-size: 13px; font-weight: 500; color: var(--itkaarhus-gray-800); }
  .itkaarhus-field input, .itkaarhus-field select, .itkaarhus-field textarea {
    font-family: inherit; font-size: 15px; padding: 11px 14px;
    border: 1px solid var(--itkaarhus-gray-300); border-radius: 6px;
    background: #fff; color: var(--itkaarhus-gray-900); outline: none;
    transition: border-color .15s, box-shadow .15s;
  }
  .itkaarhus-field input:focus, .itkaarhus-field select:focus { border-color: var(--itkaarhus-blue-500); box-shadow: var(--itkaarhus-focus); }
  .itkaarhus-field .help { font-size: 12px; color: var(--itkaarhus-gray-500); }

  /* Custom select — hide native caret, draw our own with comfortable right spacing */
  .itkaarhus-select { position: relative; }
  .itkaarhus-select select {
    width: 100%; appearance: none; -webkit-appearance: none; -moz-appearance: none;
    padding-right: 40px; /* room for the caret so text never collides with it */
  }
  .itkaarhus-select::-ms-expand { display: none; }
  .itkaarhus-select .caret {
    position: absolute; top: 50%; right: 14px; transform: translateY(-50%);
    width: 18px; height: 18px; color: var(--itkaarhus-gray-500); pointer-events: none;
  }

  /* Checkbox & radio — native control, brand accent */
  .choice-group { display: flex; flex-direction: column; gap: 12px; }
  .choice { display: inline-flex; align-items: center; gap: 10px; font-size: 15px; color: var(--itkaarhus-gray-900); cursor: pointer; }
  .choice input { width: 18px; height: 18px; margin: 0; accent-color: var(--itkaarhus-blue-500); cursor: pointer; }
  .choice input:focus-visible { outline: none; box-shadow: var(--itkaarhus-focus); border-radius: 4px; }
  .choice input:disabled { cursor: not-allowed; }
  .choice input:disabled + span { color: var(--itkaarhus-gray-400); }

  /* Toggle — checkbox styled as a switch */
  .itkaarhus-toggle { display: inline-flex; align-items: center; gap: 10px; font-size: 15px; color: var(--itkaarhus-gray-900); cursor: pointer; }
  .itkaarhus-toggle input { position: absolute; opacity: 0; width: 0; height: 0; }
  .itkaarhus-toggle .track {
    position: relative; flex: none; width: 40px; height: 22px; border-radius: var(--itkaarhus-radius-pill);
    background: var(--itkaarhus-gray-300); transition: background .15s;
  }
  .itkaarhus-toggle .track::after {
    content: ""; position: absolute; top: 2px; left: 2px; width: 18px; height: 18px;
    border-radius: 50%; background: #fff; box-shadow: var(--itkaarhus-shadow-1); transition: transform .15s;
  }
  .itkaarhus-toggle input:checked + .track { background: var(--itkaarhus-blue-500); }
  .itkaarhus-toggle input:checked + .track::after { transform: translateX(18px); }
  .itkaarhus-toggle input:focus-visible + .track { box-shadow: var(--itkaarhus-focus); }
  .itkaarhus-toggle input:disabled + .track { opacity: .5; }
  .itkaarhus-toggle input:disabled ~ .toggle-label { color: var(--itkaarhus-gray-400); }
  .itkaarhus-toggle input:disabled { cursor: not-allowed; }

  /* -- Card --------------------------------------------------- */
  .itkaarhus-card { background: #fff; border: 1px solid var(--itkaarhus-gray-200); border-radius: 12px; overflow: hidden; display: flex; flex-direction: column; }
  .itkaarhus-card__image { aspect-ratio: 16/9; background: var(--itkaarhus-blue-500); position: relative; overflow: hidden; }
