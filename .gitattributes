# Keep the Composer dist archive lean: ship only the package payload
# (assets/, LICENSE, README, CHANGELOG, composer.json). The Astro
# authoring site and its tooling are dev-only. assets/ must NOT be
# export-ignored — it is the payload consumers install.
/.astro          export-ignore
/.claude         export-ignore
/.github         export-ignore
/.gitattributes  export-ignore
/.gitignore      export-ignore
/astro.config.mjs export-ignore
/CLAUDE.md       export-ignore
/dist            export-ignore
/package.json    export-ignore
/package-lock.json export-ignore
/public          export-ignore
/src             export-ignore
/tsconfig.json   export-ignore
