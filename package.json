{
  "name": "itkaarhus-design-system",
  "type": "module",
  "version": "0.3.0",
  "private": true,
  "engines": {
    "node": ">=22.12.0"
  },
  "scripts": {
    "sync:vendor": "node -e \"import('node:fs').then(fs=>{fs.mkdirSync('public/examples/vendor',{recursive:true});fs.copyFileSync('node_modules/chart.js/dist/chart.umd.min.js','public/examples/vendor/chart.umd.min.js')})\"",
    "predev": "npm run sync:vendor",
    "dev": "astro dev",
    "prebuild": "npm run sync:vendor",
    "build": "astro build",
    "preview": "astro preview",
    "astro": "astro"
  },
  "devDependencies": {
    "astro": "^7.0.3"
  },
  "dependencies": {
    "chart.js": "^4.5.1"
  }
}
